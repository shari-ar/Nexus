# Nexus Docker development environment
COMPOSE_PROJECT_NAME=nexus
COMPOSE_PROFILES=core
NEXUS_ENV=development
NEXUS_LOG_LEVEL=debug
NEXUS_HOST=127.0.0.1

# Local service ports
OPEN_WEBUI_PORT=8080

# Open WebUI development settings
OPEN_WEBUI_IMAGE_TAG=main
OPEN_WEBUI_NAME=Nexus Dev
OPEN_WEBUI_AUTH=False
OPEN_WEBUI_ENABLE_SIGNUP=True
OPEN_WEBUI_DEFAULT_USER_ROLE=admin
OPEN_WEBUI_ENABLE_OPENAI_API=True
OPEN_WEBUI_OPENAI_API_BASE_URLS=http://vllm:8080/v1
OPEN_WEBUI_OPENAI_API_KEYS=nexus-dev-key
OPEN_WEBUI_ENABLE_OLLAMA_API=False
OPEN_WEBUI_ENABLE_PERSISTENT_CONFIG=False
OPEN_WEBUI_OFFLINE_MODE=True
OPEN_WEBUI_HF_HUB_OFFLINE=1
OPEN_WEBUI_ENABLE_VERSION_UPDATE_CHECK=False
CREWAI_PORT=8081
OPENHANDS_PORT=8082
VLLM_PORT=8083

# Local paths
NEXUS_DATA_DIR=./data
NEXUS_MEMORY_DIR=./memory
NEXUS_LOGS_DIR=./logs
NEXUS_WORKSPACES_DIR=./data/workspaces
NEXUS_PROJECTS_DIR=./data/projects
NEXUS_GENERATED_DIR=./data/generated
MODEL_ROOT=./models

# Model placeholders for later milestones
REASONING_MODEL_PATH=./models/reasoning
CODING_MODEL_PATH=./models/coding
VISION_MODEL_PATH=./models/vision
IMAGE_MODEL_PATH=./models/image
AUDIO_MODEL_PATH=./models/audio
