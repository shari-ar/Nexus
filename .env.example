# Nexus Docker development environment
COMPOSE_PROJECT_NAME=nexus
COMPOSE_PROFILES=core
NEXUS_ENV=development
NEXUS_LOG_LEVEL=debug
NEXUS_HOST=127.0.0.1

# Local service ports
OPEN_WEBUI_PORT=8080

# Open WebUI development settings
OPEN_WEBUI_IMAGE_TAG=main
OPEN_WEBUI_NAME=Nexus Dev
OPEN_WEBUI_AUTH=False
OPEN_WEBUI_ENABLE_SIGNUP=True
OPEN_WEBUI_DEFAULT_USER_ROLE=admin
OPEN_WEBUI_ENABLE_OPENAI_API=True
OPEN_WEBUI_OPENAI_API_BASE_URLS=http://vllm:8000/v1
OPEN_WEBUI_OPENAI_API_KEYS=nexus-dev-key
OPEN_WEBUI_ENABLE_OLLAMA_API=False
OPEN_WEBUI_ENABLE_PERSISTENT_CONFIG=False
OPEN_WEBUI_OFFLINE_MODE=True
OPEN_WEBUI_HF_HUB_OFFLINE=1
OPEN_WEBUI_ENABLE_VERSION_UPDATE_CHECK=False
CREWAI_PORT=8081
OPENHANDS_PORT=8082
VLLM_PORT=8083

# vLLM local model serving
VLLM_IMAGE=vllm/vllm-openai-cpu
VLLM_IMAGE_TAG=latest-x86_64
VLLM_GPU_IMAGE=vllm/vllm-openai
VLLM_GPU_IMAGE_TAG=latest
VLLM_CONTAINER_PORT=8000
VLLM_MODEL_NAME=nexus-local
VLLM_MODEL_PATH=Qwen/Qwen2.5-0.5B-Instruct
VLLM_TENSOR_PARALLEL_SIZE=1
VLLM_MAX_MODEL_LEN=2048
VLLM_DTYPE=auto
VLLM_SHM_SIZE=4g
VLLM_CPU_KVCACHE_SPACE=4
VLLM_GPU_MEMORY_UTILIZATION=0.90
VLLM_GPU_COUNT=all
VLLM_LOGGING_LEVEL=INFO
VLLM_NO_USAGE_STATS=1
HUGGING_FACE_HUB_TOKEN=

# Local paths
NEXUS_DATA_DIR=./data
NEXUS_MEMORY_DIR=./memory
NEXUS_LOGS_DIR=./logs
NEXUS_WORKSPACES_DIR=./data/workspaces
NEXUS_PROJECTS_DIR=./data/projects
NEXUS_GENERATED_DIR=./data/generated
MODEL_ROOT=./models

# Model profiles
REASONING_MODEL_NAME=nexus-reasoning
REASONING_MODEL_PATH=Qwen/Qwen2.5-0.5B-Instruct
CODING_MODEL_NAME=nexus-coding
CODING_MODEL_PATH=Qwen/Qwen2.5-Coder-0.5B-Instruct
VISION_MODEL_PATH=./models/vision
IMAGE_MODEL_PATH=./models/image
AUDIO_MODEL_PATH=./models/audio

# CrewAI orchestration runtime
CREWAI_URL=http://127.0.0.1:8081
